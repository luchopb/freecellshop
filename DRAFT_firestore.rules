rules_version = '2';
service cloudfireastore {
  match /databases/{database}/documents {

    // --- Global Safety Net: Default Deny ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Global Relational Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Domain Rules ---

    // 1. User Profiles
    // Path: /users/{userId}
    match /users/{userId} {
      allow get: if isOwner(userId);
      // Deny standard list/queries to prevent listing out other users' PII
      allow list: if false;
      
      allow create: if isOwner(userId)
        && isValidUserProfile(incoming())
        && incoming().createdAt == request.time;
        
      allow update: if isOwner(userId)
        && isValidUserProfile(incoming())
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'email', 'updatedAt']);
        
      allow delete: if false; // Profiles cannot be self-deleted in this flow
    }

    function isValidUserProfile(data) {
      return data.userId is string 
        && data.userId == request.auth.uid
        && data.email is string 
        && data.email.size() <= 256
        && (data.displayName == null || (data.displayName is string && data.displayName.size() <= 128))
        && (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 1024));
    }


    // 2. Shopping Carts
    // Path: /carts/{userId}
    match /carts/{userId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId); // list checks restricted directly to owner
      
      allow create: if isOwner(userId)
        && isValidCart(incoming())
        && incoming().updatedAt == request.time;
        
      allow update: if isOwner(userId)
        && isValidCart(incoming())
        && incoming().updatedAt == request.time;
        
      allow delete: if isOwner(userId);
    }

    function isValidCart(data) {
      return data.userId is string
        && data.userId == request.auth.uid
        && data.items is list
        && data.items.size() <= 200; // Limit cart item counts
    }


    // 3. Purchase Orders
    // Path: /orders/{orderId}
    match /orders/{orderId} {
      allow get: if isSignedIn() && (existing().userId == request.auth.uid);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid; // Secure query enforcement
      
      allow create: if isValidId(orderId)
        && isValidOrder(incoming())
        && incoming().status == 'pending'
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;
        
      allow update: if isSignedIn()
        && isValidId(orderId)
        && isValidOrder(incoming())
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        // Normal users can only transition their pending orders or cancel them
        && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])
        && (incoming().status == 'cancelled' && existing().status == 'pending');
        
      allow delete: if false; // orders are permanent receipts
    }

    function isValidOrder(data) {
      return data.orderId is string
        && data.userId is string
        && data.customerName is string
        && data.customerName.size() <= 128
        && data.customerEmail is string
        && data.customerEmail.size() <= 256
        && data.phone is string
        && data.phone.size() <= 64
        && data.shippingAddress is string
        && data.shippingAddress.size() <= 512
        && data.totalAmount is number
        && data.totalAmount >= 0
        && data.items is list
        && data.items.size() > 0
        && data.items.size() <= 200
        && data.status is string
        && data.status in ['pending', 'processing', 'completed', 'cancelled', 'cancelled_by_user'];
    }


    // 4. Contact Desk Messages
    // Path: /contactMessages/{messageId}
    match /contactMessages/{messageId} {
      allow create: if isValidId(messageId)
        && isValidContactMessage(incoming())
        && incoming().createdAt == request.time;
        
      // Messages are write-only for audience (cannot be listed, viewed, edited, or deleted from client)
      allow get, list, update, delete: if false;
    }

    function isValidContactMessage(data) {
      return data.messageId is string
        && data.name is string
        && data.name.size() <= 128
        && data.email is string
        && data.email.size() <= 256
        && data.message is string
        && data.message.size() <= 5000;
    }
  }
}
