{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information created upon registration or first sign-in.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The unique Firebase Auth UID."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "User email address."
        },
        "displayName": {
          "type": "string",
          "description": "User display name."
        },
        "photoURL": {
          "type": "string",
          "description": "User profile photo URL."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Last update timestamp."
        }
      },
      "required": ["userId", "email", "createdAt", "updatedAt"]
    },
    "ContactMessage": {
      "title": "ContactMessage",
      "description": "Support tickets and inquiries submitted from the website Contact Desk.",
      "type": "object",
      "properties": {
        "messageId": {
          "type": "string",
          "description": "Autogenerated unique message document ID."
        },
        "name": {
          "type": "string",
          "description": "Full name of the sender."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email address of the sender."
        },
        "message": {
          "type": "string",
          "description": "Message string."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Submission/server timestamp."
        }
      },
      "required": ["messageId", "name", "email", "message", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "A purchase order placed by a customer.",
      "type": "object",
      "properties": {
        "orderId": {
          "type": "string",
          "description": "The unique ID of the order."
        },
        "userId": {
          "type": "string",
          "description": "The UID of the user who made the purchase."
        },
        "customerName": {
          "type": "string",
          "description": "Shipping name."
        },
        "customerEmail": {
          "type": "string",
          "format": "email",
          "description": "Billing/receipt email."
        },
        "phone": {
          "type": "string",
          "description": "Contact phone number."
        },
        "shippingAddress": {
          "type": "string",
          "description": "Delivery address."
        },
        "items": {
          "type": "array",
          "description": "Array of products purchased in this order with quantities."
        },
        "totalAmount": {
          "type": "number",
          "description": "Total checkout price in dollars."
        },
        "status": {
          "type": "string",
          "enum": ["pending", "processing", "completed", "cancelled"],
          "description": "Order fulfillment status."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Purchase timestamp."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Status or detail alteration timestamp."
        }
      },
      "required": ["orderId", "userId", "customerName", "customerEmail", "phone", "shippingAddress", "items", "totalAmount", "status", "createdAt", "updatedAt"]
    },
    "Cart": {
      "title": "Cart",
      "description": "User's persistent dynamic shopping cart state.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The unique owner UID."
        },
        "items": {
          "type": "array",
          "description": "List of current CartItem elements."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Last saved timestamp."
        }
      },
      "required": ["userId", "items", "updatedAt"]
    },
    "Producto": {
      "title": "Producto",
      "description": "Tabla de productos sincronizados de MercadoLibre o estáticos de la tienda.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "El identificador único o código del producto."
        },
        "nombre": {
          "type": "string",
          "description": "Nombre comercial del producto."
        },
        "categoria": {
          "type": "string",
          "description": "Categoría a la que pertenece (smartphones, accessories, gadgets)."
        },
        "precio": {
          "type": "number",
          "description": "Precio de venta en dólares USD."
        },
        "precioOriginal": {
          "type": "number",
          "description": "Precio original de mercado antes del descuento."
        },
        "descripcion": {
          "type": "string",
          "description": "Descripción o detalles del artículo."
        },
        "calificacion": {
          "type": "number",
          "description": "Calificación promedio del artículo de 1 a 5."
        },
        "imagen": {
          "type": "string",
          "description": "Enlace de imágen URL del producto."
        },
        "etiquetas": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Etiquetas de marketing o destaque."
        },
        "especificaciones": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Especificaciones técnicas del hardware."
        },
        "caracteristicas": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Características o garantías clave."
        },
        "enStock": {
          "type": "boolean",
          "description": "Estado de inventario disponible."
        },
        "esNuevo": {
          "type": "boolean",
          "description": "Indicador si el producto es nuevo en catálogo."
        },
        "enlaceMercadoLibre": {
          "type": "string",
          "description": "Enlace de origen de MercadoLibre para scraping o referencia."
        }
      },
      "required": ["id", "nombre", "categoria", "precio", "descripcion", "imagen"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles database."
    },
    "/carts/{userId}": {
      "schema": "Cart",
      "description": "Active shopping carts assigned per authenticated user."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Sales history registry."
    },
    "/contactMessages/{messageId}": {
      "schema": "ContactMessage",
      "description": "Customer contact tickets collection."
    },
    "/productos/{productoId}": {
      "schema": "Producto",
      "description": "Catálogo completo de productos de la tienda."
    }
  }
}
